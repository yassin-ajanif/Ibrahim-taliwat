<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Services.ViewModels"
             x:Class="GestionCommerciale.Modules.Services.Views.ServiceEditView"
             x:DataType="vm:ServiceEditViewModel">
  <ScrollViewer>
    <StackPanel Spacing="12" MaxWidth="640">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{Binding BtnBack}" Command="{Binding BackCommand}" IsVisible="{Binding ShowBackButton}"/>
        <Button Content="{Binding BtnSave}" Command="{Binding SaveCommand}" Classes="primary"/>
      </StackPanel>

      <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>

      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="8">
          <StackPanel VerticalAlignment="Center" Spacing="6">
            <Button Classes="pos-qty" Content="+" ToolTip.Tip="{Binding BtnChooseImage}"
                    Command="{Binding PickImageCommand}" IsEnabled="{Binding FicheEditable}"/>
            <Button Classes="pos-delete" ToolTip.Tip="{Binding BtnRemovePhoto}"
                    Command="{Binding ClearFicheImageCommand}" IsEnabled="{Binding CanRemoveFicheImage}">
              <Viewbox Width="14" Height="14">
                <Path Fill="{DynamicResource CourseraDangerBrush}"
                      Data="M6,7 L6,19 C6,20.1 6.9,21 8,21 L16,21 C17.1,21 18,20.1 18,19 L18,7 L6,7 Z M19,4 L15.5,4 L14.5,3 L9.5,3 L8.5,4 L5,4 L5,6 L19,6 Z"/>
              </Viewbox>
            </Button>
          </StackPanel>
          <Border Width="120" Height="120" CornerRadius="8" BorderBrush="#28000000" BorderThickness="1"
                  Background="#0C000000" ClipToBounds="True" ToolTip.Tip="{Binding LblPhoto}">
            <Image Source="{Binding FicheImagePreview}" Stretch="Uniform"/>
          </Border>
        </StackPanel>
      </Grid>

      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LblReference}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Reference}" Watermark="{Binding WmRefExample}" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LblDesignation}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Designation}" Watermark="{Binding WmLibelle}" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LblUnite}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Unite}" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding LblPrixVente}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding PrixVenteHt}" FormatString="N2" Minimum="0"
                       ShowButtonSpinner="False" HorizontalAlignment="Left" MinWidth="160" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding LblCout}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding CoutHt}" FormatString="N2" Minimum="0"
                       ShowButtonSpinner="False" HorizontalAlignment="Left" MinWidth="160" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding LblTva}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding TauxTva}" FormatString="N0" Minimum="0"
                       ShowButtonSpinner="False" HorizontalAlignment="Left" MinWidth="160" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding ChkActif}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,10"/>
        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding Actif}" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="{Binding LblNote}" VerticalAlignment="Top" Opacity="0.7" Margin="0,4,12,0"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Note}" AcceptsReturn="True" MinHeight="80" TextWrapping="Wrap"/>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
