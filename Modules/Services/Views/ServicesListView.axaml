<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Services.ViewModels"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.Services.Views.ServicesListView"
             x:Name="ServicesListRoot"
             x:DataType="vm:ServicesListViewModel">
  <Grid ColumnDefinitions="440,*" Margin="0,0,0,8">
    <!-- Left side: services list -->
    <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
        <Button Content="{Binding BtnNew}" Command="{Binding NewCommand}"/>
        <TextBox MinWidth="220" Watermark="{Binding SearchText, TargetNullValue='Rechercher…'}"
                 Text="{Binding SearchText}" Margin="12,0,0,0"/>
      </StackPanel>

      <Grid Grid.Row="1" RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="8,6" Background="{DynamicResource CourseraSurfaceMutedBrush}"
                CornerRadius="8,8,0,0" BorderThickness="1,1,1,0"
                BorderBrush="{DynamicResource CourseraBorderBrush}">
          <Grid ColumnDefinitions="120,*,80,120,80,60">
            <TextBlock Grid.Column="0" Text="{Binding ColReference}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="1" Text="{Binding ColDesignation}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="2" Text="{Binding ColUnite}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="3" Text="{Binding ColPrix}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="4" Text="{Binding ColTva}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="5" Text="{Binding ColActif}" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <ListBox Grid.Row="1" ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                 BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CourseraBorderBrush}"
                 Background="{DynamicResource CourseraSurfaceBrush}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ServicesListRow">
              <Border Padding="8,6" Background="Transparent">
                <Border.ContextMenu>
                  <ContextMenu Opening="OnRowContextMenuOpening">
                    <MenuItem Header="Supprimer"
                              Command="{Binding $parent[UserControl].((vm:ServicesListViewModel)DataContext).DeleteCommand}"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="120,*,80,120,80,60">
                  <TextBlock Grid.Column="0" Text="{Binding Service.Reference}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding Service.Designation}" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                  <TextBlock Grid.Column="2" Text="{Binding Service.Unite}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <TextBlock Grid.Column="3" Text="{Binding PrixLabel}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <TextBlock Grid.Column="4" Text="{Binding TvaLabel}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <TextBlock Grid.Column="5" Text="{Binding ActifLabel}" VerticalAlignment="Center"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
    </Grid>

    <!-- Right side: embedded service fiche -->
    <Border Grid.Column="1" Margin="16,0,0,0" Padding="12,10,12,12"
            CornerRadius="8" BorderBrush="#28000000" BorderThickness="1"
            Background="#06000000">
      <ContentControl Content="{Binding Details}"/>
    </Border>
  </Grid>
</UserControl>
